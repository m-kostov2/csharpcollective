}
@model CSharpCollective.Services.DtoModels.PostDto;
<div class="main">
    <partial name="_Sidebar" />

    <h2>Edit Post</h2>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" style="display:flex;flex-direction:column;">
        <h1>Edit</h1>
        <p>Title</p>
        <input name="Title" />
        <p>Content</p>
        <input name="Content" /> <br />
        <button type="submit">Save</button>
    </form>
   

</div>



