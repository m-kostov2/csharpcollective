@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var userId = HttpContextAccessor.HttpContext.Session.GetString("UserId");
    var role = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CSharpCollective</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CSharpCollective.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav id="navigation1" class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="MainPage" asp-action="MainPage">CSharpCollective</a>
                <button class="navbar-toggler" type="button" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse flex-grow-1">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="MainPage" asp-action="MainPage">Home</a>
                        </li>
                        <!-- <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>-->
                        <li>
                            <input type="text" placeholder="Search..">
                        </li>

                    </ul>
                    @if (userId == "" || userId==null)
                    {
                        <div id="nav-1">
                            <ul>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Login" asp-action="Login">Sign in</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Register" asp-action="Register">Sign up</a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div id="nav-2-logged">
                            <ul>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Login" asp-action="logOut">logOut</a>
                                </li>
                              </ul>
                        </div>
                    
                    }


                </div>
            </div>
        </nav>
    </header>
    <div>
    </div>
    <div class="container">

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
   
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CSharpCollective - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
     <script src="~/lib/jquery/dist/jquery.min.js"></script>
     <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
